+    private fun resolveCssVariables(
+        value: String,
+        customProperties: Map<String, String>,
+        depth: Int = 0
+    ): String {
+        if (depth > 20 || !value.contains("var(", ignoreCase = true)) return value.trim()
+
+        val output = StringBuilder()
+        var index = 0
+        var quote: Char? = null
+
+        while (index < value.length) {
+            val char = value[index]
+            if (quote != null) {
+                output.append(char)
+                if (char == quote) quote = null
+                index++
+                continue
+            }
+
+            if (char == '\'' || char == '"') {
+                quote = char
+                output.append(char)
+                index++
+                continue
+            }
+
+            if (value.regionMatches(index, "var(", 0, 4, ignoreCase = true)) {
+                val closeIndex = findMatchingParen(value, index + 3)
+                if (closeIndex > index) {
+                    val body = value.substring(index + 4, closeIndex)
+                    val replacement = resolveSingleVar(body, customProperties, depth)
+                    output.append(replacement)
+                    index = closeIndex + 1
+                    continue
+                }
+            }
+
+            output.append(char)
+            index++
+        }
+
+        return output.toString().trim()
+    }
+
+    private fun resolveSingleVar(
+        body: String,
+        customProperties: Map<String, String>,
+        depth: Int
+    ): String {
+        val commaIndex = findTopLevelComma(body)
+        val name = if (commaIndex >= 0) body.substring(0, commaIndex).trim() else body.trim()
+        val fallback = if (commaIndex >= 0) body.substring(commaIndex + 1).trim() else null
+
+        if (!name.startsWith("--")) {
+            return fallback?.let { resolveCssVariables(it, customProperties, depth + 1) }.orEmpty()
+        }
+
+        val rawValue = customProperties[name]
+        return when {
+            rawValue != null -> resolveCssVariables(rawValue, customProperties, depth + 1)
+            fallback != null -> resolveCssVariables(fallback, customProperties, depth + 1)
+            else -> ""
+        }
+    }
+
+    private fun findMatchingParen(value: String, openParenIndex: Int): Int {
+        var index = openParenIndex + 1
+        var depth = 1
+        var quote: Char? = null
+
+        while (index < value.length) {
+            val char = value[index]
+            when {
+                quote != null -> {
+                    if (char == quote) quote = null
+                }
+                char == '\'' || char == '"' -> quote = char
+                char == '(' -> depth++
+                char == ')' -> {
+                    depth--
+                    if (depth == 0) return index
+                }
+            }
+            index++
+        }
+        return -1
+    }
+
+    private fun findTopLevelComma(value: String): Int {
+        var parenDepth = 0
+        var quote: Char? = null
+
+        value.forEachIndexed { index, char ->
+            when {
+                quote != null -> {
+                    if (char == quote) quote = null
+                }
+                char == '\'' || char == '"' -> quote = char
+                char == '(' -> parenDepth++
+                char == ')' -> parenDepth = (parenDepth - 1).coerceAtLeast(0)
+                char == ',' && parenDepth == 0 -> return index
+            }
+        }
+
+        return -1
+    }
