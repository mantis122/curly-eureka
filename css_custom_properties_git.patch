+    private fun splitCssDeclarations(css: String): List<String> {
+        val declarations = mutableListOf<String>()
+        val current = StringBuilder()
+        var parenDepth = 0
+        var quote: Char? = null
+
+        css.forEach { char ->
+            when {
+                quote != null -> {
+                    current.append(char)
+                    if (char == quote) quote = null
+                }
+                char == '\'' || char == '"' -> {
+                    quote = char
+                    current.append(char)
+                }
+                char == '(' -> {
+                    parenDepth++
+                    current.append(char)
+                }
+                char == ')' -> {
+                    parenDepth = (parenDepth - 1).coerceAtLeast(0)
+                    current.append(char)
+                }
+                char == ';' && parenDepth == 0 -> {
+                    current.toString().trim().takeIf { it.isNotBlank() }?.let { declarations.add(it) }
+                    current.clear()
+                }
+                else -> current.append(char)
+            }
+        }
+
+        current.toString().trim().takeIf { it.isNotBlank() }?.let { declarations.add(it) }
+        return declarations
+    }
+
+    private fun findTopLevelColon(value: String): Int {
+        var parenDepth = 0
+        var bracketDepth = 0
+        var quote: Char? = null
+
+        value.forEachIndexed { index, char ->
+            when {
+                quote != null -> {
+                    if (char == quote) quote = null
+                }
+                char == '\'' || char == '"' -> quote = char
+                char == '(' -> parenDepth++
+                char == ')' -> parenDepth = (parenDepth - 1).coerceAtLeast(0)
+                char == '[' -> bracketDepth++
+                char == ']' -> bracketDepth = (bracketDepth - 1).coerceAtLeast(0)
+                char == ':' && parenDepth == 0 && bracketDepth == 0 -> return index
+            }
+        }
+
+        return -1
+    }
+
+    private fun normalizeCssDeclarations(css: String): String {
