+    private fun markerIdFromValue(value: String?): String? {
+        val v = value?.trim().orEmpty()
+        if (v.isBlank() || v.equals("none", ignoreCase = true)) return null
+        return Regex("""url\(\s*#([^)'"\s]+)\s*\)""")
+            .find(v)
+            ?.groupValues
+            ?.getOrNull(1)
+            ?.trim()
+            ?.takeIf { it.isNotBlank() }
+    }
