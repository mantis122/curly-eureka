+                ?: element.getAttribute("marker-start").ifBlank { "" }
+        ) ?: markerAll
+        val markerMid = markerIdFromValue(
+            SvgPaintResolver.styleValue(style, "marker-mid")
+                ?: element.getAttribute("marker-mid").ifBlank { "" }
+        ) ?: markerAll
