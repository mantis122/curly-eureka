+                inheritedStrokeWidth = inheritedStrokeWidth,
+                inheritedFillAlpha = inheritedFillAlpha,
+                inheritedStrokeAlpha = inheritedStrokeAlpha,
+                indent = indent
+            )
+        }
+    }
