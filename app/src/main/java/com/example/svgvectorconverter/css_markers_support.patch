+    private fun angleBetween(from: Pair<Float, Float>, to: Pair<Float, Float>): Float {
+        return Math.toDegrees(kotlin.math.atan2((to.second - from.second).toDouble(), (to.first - from.first).toDouble())).toFloat()
+    }
